---
layout: layouts/base.njk
title: Welcome
titleOnly: true
description: Welcome to my website.
nav: home
bodyClass: home-page
hideHeader: true
---
<main>
  <section class="welcome" aria-labelledby="welcome-title">
    <h1 id="welcome-title">to</h1>
    <p class="welcome-line">my website.</p>
    <a class="scroll-cue" href="#latest" aria-label="向下查看最新文章">
      <span aria-hidden="true">↓</span>
    </a>
  </section>

  <section id="latest" class="home-content">
    <div class="section-heading">
      <div>
        <h2>最新文章</h2>
      </div>
      <a href="{{ '/articles.html' | sitePath }}">查看全部 →</a>
    </div>

    <section class="listing" aria-label="最新文章">
      {% set posts = collections.posts | limit(3) %}
      {% include "components/post-list.njk" %}
    </section>

    <section class="home-about" aria-labelledby="home-about-title">
      <h2 id="home-about-title">
        <a href="{{ '/about.html' | sitePath }}">关于</a>
      </h2>
    </section>
  </section>
</main>
