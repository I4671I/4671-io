---
layout: layouts/base.njk
title: Welcome
titleOnly: true
description: Welcome to my website.
nav: home
bodyClass: home-page
hideHeader: true
---
<main class="home-main">
  <section class="welcome" aria-labelledby="welcome-title">
    <h1 id="welcome-title">to</h1>
    <p class="welcome-line">my website.</p>
    <a class="scroll-cue" href="#latest" aria-label="向下查看最新文章">
      <span>Scroll</span>
      <span aria-hidden="true">↓</span>
    </a>
  </section>

  <section id="latest" class="home-content">
    <header class="home-nav">
      <a class="site-name" href="/">{{ site.name }}</a>
      <nav aria-label="主导航">
        <a href="/articles.html">文章</a>
        <a href="/about.html">关于</a>
      </nav>
    </header>

    <div class="section-heading">
      <div>
        <p>RECENT WRITING</p>
        <h2>最新文章</h2>
      </div>
      <a href="/articles.html">查看全部 →</a>
    </div>

    <section class="listing" aria-label="最新文章">
      {% set posts = collections.posts | limit(3) %}
      {% include "components/post-list.njk" %}
    </section>
  </section>
</main>
