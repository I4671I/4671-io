---
layout: layouts/base.njk
title: 标签
description: 按标签浏览文章
nav: tags
permalink: tags.html
---
<main>
  <section class="hero" aria-labelledby="tags-title">
    <p>TAGS</p>
    <h1 id="tags-title">标签</h1>
  </section>

  {% set allTags = collections.tagList %}
  {% if allTags.length %}
    <section class="archive-tags" aria-label="全部标签">
      <div class="tag-list">
        {% for tag in allTags %}
          <a href="{{ tag | tagUrl }}">
            <span>#{{ tag }}</span>
            <span>共 {{ collections[tag].length }} 篇</span>
          </a>
        {% endfor %}
      </div>
    </section>
  {% endif %}
</main>
