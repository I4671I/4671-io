---
layout: layouts/base.njk
postLayout: true
bodyClass: post-page
---
<div class="reading-layout">
  {% set headings = content | articleHeadings %}
  {% include "components/article-sidebar.njk" %}

  <main>
    <article class="post">
      <header>
        <p class="meta">
          <time datetime="{{ date | htmlDateString }}">{{ date | displayDate }}</time>
          <span>·</span><span>阅读约 {{ readingTime or (content | readingTime) }} 分钟</span>
        </p>
        <h1>{{ title }}</h1>
        {% if description %}<p>{{ description }}</p>{% endif %}
        {% if tags.length %}
          <div class="post-tags">
            {% for tag in tags %}
              {% if tag != "post" %}<a href="{{ tag | tagUrl }}">#{{ tag }}</a>{% endif %}
            {% endfor %}
          </div>
        {% endif %}
      </header>
      <div class="post-content">
        {{ content | addHeadingIds | safe }}
        {% set previousPost = collections.posts | adjacentPost(page.url, -1) %}
        {% set nextPost = collections.posts | adjacentPost(page.url, 1) %}
        <nav class="post-navigation" aria-label="相邻文章">
          <span>
            {% if previousPost %}
              <a
                href="{{ previousPost.url | sitePath }}"
                rel="prev"
                aria-label="上一篇：{{ previousPost.data.title }}"
                title="{{ previousPost.data.title }}"
              >
                <span aria-hidden="true">←</span>
                <span class="post-navigation-title">{{ previousPost.data.title }}</span>
              </a>
            {% endif %}
          </span>
          <a class="back-link" href="{{ '/articles.html' | sitePath }}">返回文章列表</a>
          <span>
            {% if nextPost %}
              <a
                href="{{ nextPost.url | sitePath }}"
                rel="next"
                aria-label="下一篇：{{ nextPost.data.title }}"
                title="{{ nextPost.data.title }}"
              >
                <span class="post-navigation-title">{{ nextPost.data.title }}</span>
                <span aria-hidden="true">→</span>
              </a>
            {% endif %}
          </span>
        </nav>
      </div>
      {% include "components/giscus.njk" %}
    </article>
  </main>
</div>
