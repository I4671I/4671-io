<!DOCTYPE html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="color-scheme" content="dark">
    <meta name="theme-color" content="#111318">
    <meta name="description" content="{{ description or site.description }}">
    <title>{% if titleOnly %}{{ title }}{% else %}{% if title %}{{ title }}｜{% endif %}{{ site.name }}{% endif %}</title>
    <style>
      html {
        color-scheme: dark;
        color: #ddd8cd;
        background: #111318;
      }

      body {
        min-height: 100vh;
        margin: 0;
        color: #ddd8cd;
        background: #111318;
      }
    </style>
    <link rel="preload" href="{{ '/assets/fonts/source-serif-4-regular.woff2' | sitePath }}" as="font" type="font/woff2" crossorigin>
    <link rel="preload" href="{{ '/assets/fonts/lxgw-zhuque-fangsong-regular.woff2' | sitePath }}" as="font" type="font/woff2" crossorigin>
    <link rel="icon" type="image/png" sizes="64x64" href="{{ '/assets/images/bicon.png' | sitePath }}">
    <link rel="shortcut icon" type="image/png" href="{{ '/assets/images/bicon.png' | sitePath }}">
    <link rel="apple-touch-icon" href="{{ '/assets/images/bicon.png' | sitePath }}">
    <link rel="stylesheet" href="{{ '/assets/css/main.css' | sitePath }}">
    {% if postLayout %}<link rel="stylesheet" href="{{ '/assets/css/post.css' | sitePath }}">{% endif %}
    <script src="{{ '/assets/js/theme-colors.js' | sitePath }}" defer></script>
    {% if postLayout %}<script src="{{ '/assets/js/article-toc.js' | sitePath }}" defer></script>{% endif %}
  </head>
  <body class="{{ bodyClass or '' }}">
    {% if not hideHeader %}
      {% include "components/header.njk" %}
    {% endif %}

    {{ content | safe }}

    {% if not hideFooter %}
      {% include "components/footer.njk" %}
    {% endif %}
  </body>
</html>
