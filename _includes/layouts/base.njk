<!DOCTYPE html>
<html lang="zh-CN" style="{% accentPalette %}">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="color-scheme" content="dark">
    <meta name="theme-color" content="#111318">
    <meta name="description" content="{{ description or site.description }}">
    <title>{% if titleOnly %}{{ title }}{% else %}{% if title %}{{ title }}｜{% endif %}{{ site.name }}{% endif %}</title>
    <script>
      document.documentElement.classList.add("fonts-loading");
    </script>
    <style>
      html {
        color-scheme: dark;
        color: #ddd8cd;
        background: #111318;
      }

      html.fonts-loading body {
        visibility: hidden;
      }

      body {
        min-height: 100vh;
        margin: 0;
        color: #ddd8cd;
        background: #111318;
      }
    </style>
    <link rel="preload" href="{{ '/assets/fonts/source-serif-4-regular.6b053e98f083.woff2' | sitePath }}" as="font" type="font/woff2" crossorigin>
    <link rel="preload" href="{{ '/assets/fonts/lxgw-zhuque-fangsong-regular.c9868022314b.woff2' | sitePath }}" as="font" type="font/woff2" crossorigin>
    {% if postLayout %}<link rel="preload" href="{{ '/assets/fonts/consolas-regular.ca23a72bc345.ttf' | sitePath }}" as="font" type="font/ttf" crossorigin>{% endif %}
    {% if postLayout %}<link rel="preload" href="{{ '/assets/fonts/simsun-regular.d865ac703c40.woff2' | sitePath }}" as="font" type="font/woff2" crossorigin>{% endif %}
    <link rel="icon" type="image/png" sizes="64x64" href="{{ '/assets/images/bicon.png' | sitePath }}">
    <link rel="shortcut icon" type="image/png" href="{{ '/assets/images/bicon.png' | sitePath }}">
    <link rel="apple-touch-icon" href="{{ '/assets/images/bicon.png' | sitePath }}">
    <link rel="stylesheet" href="{{ '/assets/css/main.css' | assetPath }}">
    {% if postLayout %}<link rel="stylesheet" href="{{ '/assets/vendor/katex/katex.min.css' | sitePath }}">{% endif %}
    {% if postLayout %}<link rel="stylesheet" href="{{ '/assets/css/post.css' | assetPath }}">{% endif %}
    <script src="{{ '/assets/js/theme-colors.js' | assetPath }}" defer></script>
    {% if postLayout %}<script src="{{ '/assets/js/article-toc.js' | assetPath }}" defer></script>{% endif %}
    <script>
      (() => {
        const root = document.documentElement;
        const reveal = () => root.classList.remove("fonts-loading");

        if (!document.fonts || typeof document.fonts.load !== "function") {
          reveal();
          return;
        }

        const requiredFonts = [
          ['1em "Source Serif 4"', "A"],
          ['1em "LXGW Zhuque Fangsong"', "汉"]{% if postLayout %},
          ['1em "Consolas Web"', "A"],
          ['1em "SimSun Web"', "汉"]{% endif %}
        ];

        const domReady = document.readyState === "loading"
          ? new Promise((resolve) => {
              document.addEventListener("DOMContentLoaded", resolve, { once: true });
            })
          : Promise.resolve();
        const fontsReady = Promise.all(
          requiredFonts.map(([font, sample]) => document.fonts.load(font, sample))
        )
          .then(() => document.fonts.ready)
          .catch(() => undefined);

        Promise.all([domReady, fontsReady]).then(reveal);
      })();
    </script>
  </head>
  <body class="{{ bodyClass or '' }}">
    {% if not hideHeader %}
      {% include "components/header.njk" %}
    {% endif %}

    {{ content | safe }}

    {% if not hideFooter %}
      {% include "components/footer.njk" %}
    {% endif %}
  </body>
</html>
